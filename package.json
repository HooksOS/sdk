{
  "name": "@hookos/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the HookOS Protocol — programmable market engine on Base",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "viem": ">=2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "viem": "^2.21.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "hookos",
    "web3",
    "defi",
    "base",
    "evm",
    "hooks",
    "launchpad",
    "bonding-curve",
    "arena",
    "sdk"
  ],
  "author": "HookOS <jinklabs@gmail.com>",
  "homepage": "https://hookos.fun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HooksOS/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/HooksOS/sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
